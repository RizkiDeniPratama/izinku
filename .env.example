# Salin file ini menjadi .env dan masukkan kredensial Anda sendiri
# Copy this file to .env and input your own credentials

# Kredensial EmailJS untuk Form Kontak
PUBLIC_EMAILJS_SERVICE_ID=YOUR_SERVICE_ID
PUBLIC_EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID
PUBLIC_EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY

# Nomor WhatsApp (gunakan kode negara tanpa +, misal: 6281234567890)
PUBLIC_WHATSAPP_NUMBER=6281234567890
