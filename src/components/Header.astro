---
import { navItems } from '../data/navigation';

const currentPath = Astro.url.pathname;
---

<header class="bg-cream/95 backdrop-blur-md sticky top-0 z-50 border-b border-primary/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-18">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group" id="header-logo">
        <div class="w-10 h-10 bg-primary rounded-lg flex items-center justify-center group-hover:bg-primary-light transition-colors">
          <svg class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.97zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.97z" />
          </svg>
        </div>
        <span class="font-heading text-2xl font-bold text-primary">IZINKU</span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-1" id="desktop-nav">
        {navItems.map((item) => {
          const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <a
              href={item.href}
              class:list={[
                'px-4 py-2 rounded-lg text-sm font-medium transition-colors relative',
                isActive
                  ? 'text-primary bg-primary/10'
                  : 'text-text-secondary hover:text-primary hover:bg-primary/5',
              ]}
            >
              {item.label}
            </a>
          );
        })}
        <a
          href="/kontak"
          class="ml-3 px-5 py-2.5 bg-gold text-white text-sm font-semibold rounded-lg hover:bg-gold-dark transition-colors"
          id="header-cta"
        >
          Konsultasi Gratis
        </a>
      </nav>

      <!-- Mobile Hamburger -->
      <button
        class="md:hidden flex flex-col gap-1.5 p-2"
        id="mobile-menu-btn"
        aria-label="Toggle menu"
      >
        <span class="block w-6 h-0.5 bg-primary transition-all duration-300" id="hamburger-top"></span>
        <span class="block w-6 h-0.5 bg-primary transition-all duration-300" id="hamburger-mid"></span>
        <span class="block w-4 h-0.5 bg-primary transition-all duration-300 ml-auto" id="hamburger-bot"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div class="mobile-nav md:hidden" id="mobile-nav">
    <div class="px-4 pb-4 space-y-1 border-t border-primary/10">
      {navItems.map((item) => {
        const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
        return (
          <a
            href={item.href}
            class:list={[
              'block px-4 py-3 rounded-lg text-sm font-medium transition-colors',
              isActive
                ? 'text-primary bg-primary/10'
                : 'text-text-secondary hover:text-primary hover:bg-primary/5',
            ]}
          >
            {item.label}
          </a>
        );
      })}
      <a
        href="/kontak"
        class="block text-center mt-2 px-5 py-3 bg-gold text-white text-sm font-semibold rounded-lg hover:bg-gold-dark transition-colors"
      >
        Konsultasi Gratis
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const nav = document.getElementById('mobile-nav');
  const top = document.getElementById('hamburger-top');
  const mid = document.getElementById('hamburger-mid');
  const bot = document.getElementById('hamburger-bot');

  btn?.addEventListener('click', () => {
    nav?.classList.toggle('open');
    top?.classList.toggle('rotate-45');
    top?.classList.toggle('translate-y-[4px]');
    mid?.classList.toggle('opacity-0');
    bot?.classList.toggle('-rotate-45');
    bot?.classList.toggle('translate-y-[-4px]');
    bot?.classList.toggle('w-6');
    bot?.classList.toggle('w-4');
  });
</script>
