---
interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
}

const { title, subtitle, centered = true } = Astro.props;
---

<div class={`mb-12 ${centered ? 'text-center' : ''}`}>
  <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary mb-4">
    {title}
  </h2>
  {subtitle && (
    <p class={`text-text-secondary text-lg max-w-2xl ${centered ? 'mx-auto' : ''}`}>
      {subtitle}
    </p>
  )}
  <div class={`mt-4 flex ${centered ? 'justify-center' : ''}`}>
    <div class="w-16 h-1 bg-gold rounded-full"></div>
  </div>
</div>
