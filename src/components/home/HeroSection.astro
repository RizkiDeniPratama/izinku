---
// Hero section for the home page
---

<section class="relative bg-primary overflow-hidden min-h-[90vh] flex items-center" id="hero">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-0 left-0 w-full h-full" style="background-image: radial-gradient(circle at 20% 50%, rgba(201,168,76,0.3) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(201,168,76,0.2) 0%, transparent 40%);"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 border border-gold/20 rounded-full -translate-x-1/4 translate-y-1/4"></div>
    <div class="absolute top-20 left-10 w-64 h-64 border border-gold/10 rounded-full"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Text Content -->
      <div class="text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-gold/20 rounded-full mb-6">
          <div class="w-2 h-2 bg-gold rounded-full animate-pulse"></div>
          <span class="text-gold text-sm font-medium">Konsultasi Gratis untuk UMKM</span>
        </div>

        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
          Mitra Hukum
          <span class="text-gold">Terpercaya</span>
          untuk Bisnis Anda
        </h1>

        <p class="text-white/70 text-lg md:text-xl leading-relaxed mb-8 max-w-xl mx-auto lg:mx-0">
          Pendirian usaha, penyusunan kontrak, dan konsultasi hukum profesional. Kami membantu UMKM Indonesia tumbuh dengan landasan hukum yang kuat.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a
            href="/kontak"
            class="px-8 py-4 bg-gold hover:bg-gold-dark text-white font-semibold rounded-lg transition-all duration-300 text-center shadow-lg shadow-gold/25 hover:shadow-xl hover:shadow-gold/30"
            id="hero-cta-primary"
          >
            Konsultasi Gratis
            <svg class="w-5 h-5 inline-block ml-1 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
          <a
            href="/layanan"
            class="px-8 py-4 border-2 border-white/30 text-white hover:bg-white/10 font-semibold rounded-lg transition-colors text-center"
            id="hero-cta-secondary"
          >
            Lihat Layanan
          </a>
        </div>

        <!-- Trust badges -->
        <div class="mt-10 flex items-center gap-6 justify-center lg:justify-start text-white/50 text-sm">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-gold" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <span>Trusted by 1,500+ UMKM</span>
          </div>
          <div class="w-px h-4 bg-white/20"></div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
            <span>Legal & Terpercaya</span>
          </div>
        </div>
      </div>

      <!-- Visual element -->
      <div class="hidden lg:flex justify-center">
        <div class="relative">
          <!-- Decorative cards -->
          <div class="w-80 h-96 bg-white/5 backdrop-blur-sm rounded-2xl border border-white/10 p-8 transform rotate-3">
            <div class="w-full h-full bg-white/5 rounded-xl flex flex-col items-center justify-center text-center gap-4">
              <div class="w-16 h-16 bg-gold/20 rounded-full flex items-center justify-center">
                <svg class="w-8 h-8 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
              </div>
              <div>
                <p class="text-gold font-heading text-lg font-semibold mb-1">Dokumen Legal</p>
                <p class="text-white/50 text-sm">Akta, NIB, SIUP & izin lainnya</p>
              </div>
              <div class="mt-4 w-full space-y-2">
                <div class="h-2 bg-gold/30 rounded-full w-full"></div>
                <div class="h-2 bg-gold/20 rounded-full w-3/4"></div>
                <div class="h-2 bg-gold/10 rounded-full w-1/2"></div>
              </div>
            </div>
          </div>

          <!-- Floating badge -->
          <div class="absolute -bottom-4 -left-8 bg-white rounded-xl shadow-xl p-4 flex items-center gap-3 animate-bounce" style="animation-duration: 3s;">
            <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            </div>
            <div>
              <p class="text-text-main text-sm font-semibold">Izin Terbit!</p>
              <p class="text-text-secondary text-xs">NIB berhasil diterbitkan</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
