---
import { getCollection } from 'astro:content';
import SectionHeading from '../SectionHeading.astro';
import BlogCard from '../blog/BlogCard.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);
---

<section class="py-16 md:py-24 bg-cream" id="latest-blog">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      title="Artikel Terbaru"
      subtitle="Wawasan hukum dan tips bisnis dari tim ahli IZINKU"
    />

    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {posts.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          slug={post.id}
          image={post.data.image}
          tags={post.data.tags}
        />
      ))}
    </div>

    <div class="text-center mt-10">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 px-6 py-3 border-2 border-primary/20 text-primary hover:bg-primary hover:text-white font-semibold rounded-lg transition-all"
        id="view-all-blog"
      >
        Lihat Semua Artikel
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
      </a>
    </div>
  </div>
</section>
