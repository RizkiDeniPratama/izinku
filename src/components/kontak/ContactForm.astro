---
// ============================================================
// EMAILJS CONFIGURATION — REPLACE THESE WITH YOUR CREDENTIALS
// ============================================================
// 1. Create an account at https://www.emailjs.com/
// 2. Create a Service (e.g., Gmail) and note the Service ID
// 3. Create an Email Template and note the Template ID
// 4. Find your Public Key in Account > API Keys
// ============================================================
const EMAILJS_SERVICE_ID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID || 'YOUR_SERVICE_ID';   // TODO: Replace with your EmailJS Service ID
const EMAILJS_TEMPLATE_ID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID || 'YOUR_TEMPLATE_ID'; // TODO: Replace with your EmailJS Template ID
const EMAILJS_PUBLIC_KEY = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY || 'YOUR_PUBLIC_KEY';    // TODO: Replace with your EmailJS Public Key
---

<form id="contact-form" class="space-y-5" novalidate>
  <!-- Name -->
  <div>
    <label for="form-name" class="block text-sm font-medium text-text-main mb-1.5">
      Nama Lengkap <span class="text-red-500">*</span>
    </label>
    <input
      type="text"
      id="form-name"
      name="name"
      required
      placeholder="Masukkan nama lengkap Anda"
      class="w-full px-4 py-3 bg-white border border-primary/10 rounded-lg text-text-main text-sm placeholder:text-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
    />
    <p class="text-red-500 text-xs mt-1 hidden" id="error-name">Nama harus diisi.</p>
  </div>

  <!-- Email -->
  <div>
    <label for="form-email" class="block text-sm font-medium text-text-main mb-1.5">
      Email <span class="text-red-500">*</span>
    </label>
    <input
      type="email"
      id="form-email"
      name="email"
      required
      placeholder="contoh@email.com"
      class="w-full px-4 py-3 bg-white border border-primary/10 rounded-lg text-text-main text-sm placeholder:text-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
    />
    <p class="text-red-500 text-xs mt-1 hidden" id="error-email">Masukkan email yang valid.</p>
  </div>

  <!-- Phone -->
  <div>
    <label for="form-phone" class="block text-sm font-medium text-text-main mb-1.5">
      Nomor Telepon <span class="text-red-500">*</span>
    </label>
    <input
      type="tel"
      id="form-phone"
      name="phone"
      required
      placeholder="08xx-xxxx-xxxx"
      class="w-full px-4 py-3 bg-white border border-primary/10 rounded-lg text-text-main text-sm placeholder:text-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
    />
    <p class="text-red-500 text-xs mt-1 hidden" id="error-phone">Masukkan nomor telepon yang valid.</p>
  </div>

  <!-- Service type -->
  <div>
    <label for="form-service" class="block text-sm font-medium text-text-main mb-1.5">
      Layanan yang Dibutuhkan
    </label>
    <select
      id="form-service"
      name="service"
      class="w-full px-4 py-3 bg-white border border-primary/10 rounded-lg text-text-main text-sm focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
    >
      <option value="">Pilih layanan...</option>
      <option value="Pendirian Usaha">Legalitas & Pendirian Usaha</option>
      <option value="MoU & Kontrak">Penyusunan MoU & Kontrak</option>
      <option value="Konsultasi Hukum">Konsultasi Hukum & Retainer</option>
      <option value="Lainnya">Lainnya</option>
    </select>
  </div>

  <!-- Message -->
  <div>
    <label for="form-message" class="block text-sm font-medium text-text-main mb-1.5">
      Pesan <span class="text-red-500">*</span>
    </label>
    <textarea
      id="form-message"
      name="message"
      required
      rows="4"
      placeholder="Ceritakan kebutuhan hukum Anda..."
      class="w-full px-4 py-3 bg-white border border-primary/10 rounded-lg text-text-main text-sm placeholder:text-text-secondary/50 focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors resize-none"
    ></textarea>
    <p class="text-red-500 text-xs mt-1 hidden" id="error-message">Pesan harus diisi.</p>
  </div>

  <!-- Honeypot field (anti-spam) — hidden from users -->
  <div class="absolute -left-[9999px]" aria-hidden="true">
    <label for="form-website">Website</label>
    <input type="text" id="form-website" name="website" tabindex="-1" autocomplete="off" />
  </div>

  <!-- Submit -->
  <button
    type="submit"
    id="form-submit"
    class="w-full px-8 py-3.5 bg-gold hover:bg-gold-dark text-white font-semibold rounded-lg transition-colors flex items-center justify-center gap-2"
  >
    <span id="submit-text">Kirim Pesan</span>
    <svg id="submit-spinner" class="w-5 h-5 animate-spin hidden" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
    </svg>
  </button>
</form>

<!-- Success toast -->
<div id="toast-success" class="fixed top-20 right-6 z-[60] hidden">
  <div class="toast bg-white rounded-xl shadow-2xl border border-green-200 p-4 flex items-start gap-3 max-w-sm">
    <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center shrink-0">
      <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
    </div>
    <div>
      <p class="font-semibold text-text-main text-sm">Pesan Terkirim!</p>
      <p class="text-text-secondary text-xs mt-0.5">Kami akan menghubungi Anda dalam 1x24 jam.</p>
    </div>
    <button onclick="document.getElementById('toast-success').classList.add('hidden')" class="text-text-secondary hover:text-text-main ml-2">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
  </div>
</div>

<!-- Error toast -->
<div id="toast-error" class="fixed top-20 right-6 z-[60] hidden">
  <div class="toast bg-white rounded-xl shadow-2xl border border-red-200 p-4 flex items-start gap-3 max-w-sm">
    <div class="w-8 h-8 bg-red-100 rounded-full flex items-center justify-center shrink-0">
      <svg class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" /></svg>
    </div>
    <div>
      <p class="font-semibold text-text-main text-sm">Gagal Mengirim</p>
      <p class="text-text-secondary text-xs mt-0.5">Terjadi kesalahan. Silakan coba lagi atau hubungi kami via WhatsApp.</p>
    </div>
    <button onclick="document.getElementById('toast-error').classList.add('hidden')" class="text-text-secondary hover:text-text-main ml-2">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
  </div>
</div>

<script define:vars={{ EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, EMAILJS_PUBLIC_KEY }}>
  // Load EmailJS SDK
  const script = document.createElement('script');
  script.src = 'https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js';
  script.onload = () => {
    emailjs.init(EMAILJS_PUBLIC_KEY);
  };
  document.head.appendChild(script);

  const form = document.getElementById('contact-form');

  function validateEmail(email) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  function validatePhone(phone) {
    return /^[\d\s\-+()]{8,15}$/.test(phone);
  }

  function showError(id) {
    document.getElementById(id)?.classList.remove('hidden');
  }

  function hideError(id) {
    document.getElementById(id)?.classList.add('hidden');
  }

  function showToast(type) {
    const toast = document.getElementById(`toast-${type}`);
    toast?.classList.remove('hidden');
    setTimeout(() => toast?.classList.add('hidden'), 5000);
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Reset errors
    ['error-name', 'error-email', 'error-phone', 'error-message'].forEach(hideError);

    const name = form.querySelector('#form-name').value.trim();
    const email = form.querySelector('#form-email').value.trim();
    const phone = form.querySelector('#form-phone').value.trim();
    const message = form.querySelector('#form-message').value.trim();
    const honeypot = form.querySelector('#form-website').value;

    // Validate
    let valid = true;
    if (!name) { showError('error-name'); valid = false; }
    if (!email || !validateEmail(email)) { showError('error-email'); valid = false; }
    if (!phone || !validatePhone(phone)) { showError('error-phone'); valid = false; }
    if (!message) { showError('error-message'); valid = false; }
    if (!valid) return;

    // Honeypot check — if filled, silently pretend success
    if (honeypot) {
      showToast('success');
      form.reset();
      return;
    }

    // Show loading
    const submitText = document.getElementById('submit-text');
    const spinner = document.getElementById('submit-spinner');
    const submitBtn = document.getElementById('form-submit');
    submitText.textContent = 'Mengirim...';
    spinner?.classList.remove('hidden');
    submitBtn.disabled = true;

    try {
      await emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, {
        from_name: name,
        from_email: email,
        phone: phone,
        service: form.querySelector('#form-service').value,
        message: message,
      });

      showToast('success');
      form.reset();
    } catch (err) {
      console.error('EmailJS error:', err);
      showToast('error');
    } finally {
      submitText.textContent = 'Kirim Pesan';
      spinner?.classList.add('hidden');
      submitBtn.disabled = false;
    }
  });
</script>
