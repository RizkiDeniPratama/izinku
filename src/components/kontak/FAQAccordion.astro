---
import { faqItems } from '../../data/faq';
---

<div class="space-y-3" id="faq-accordion">
  {faqItems.map((item, index) => (
    <div class="bg-white rounded-xl border border-primary/5 overflow-hidden" id={`faq-item-${index}`}>
      <button
        class="w-full flex items-center justify-between p-5 text-left gap-4 hover:bg-cream-alt transition-colors"
        data-faq-trigger
        aria-expanded="false"
      >
        <span class="font-semibold text-text-main text-sm">{item.question}</span>
        <svg class="faq-chevron w-5 h-5 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
        </svg>
      </button>
      <div class="faq-content">
        <div class="px-5 pb-5 text-text-secondary text-sm leading-relaxed">
          {item.answer}
        </div>
      </div>
    </div>
  ))}
</div>

<script>
  const faqContainer = document.getElementById('faq-accordion');
  if (faqContainer) {
    const triggers = faqContainer.querySelectorAll('[data-faq-trigger]');
    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const content = trigger.nextElementSibling as HTMLElement;
        const chevron = trigger.querySelector('.faq-chevron') as HTMLElement;
        const isOpen = content?.classList.contains('open');

        // Close all others
        faqContainer.querySelectorAll('.faq-content').forEach((c) => c.classList.remove('open'));
        faqContainer.querySelectorAll('.faq-chevron').forEach((c) => c.classList.remove('open'));
        faqContainer.querySelectorAll('[data-faq-trigger]').forEach((t) => t.setAttribute('aria-expanded', 'false'));

        // Toggle current
        if (!isOpen && content && chevron) {
          content.classList.add('open');
          chevron.classList.add('open');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }
</script>
