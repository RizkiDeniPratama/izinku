---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ServiceCard from '../../components/layanan/ServiceCard.astro';
import CTABanner from '../../components/CTABanner.astro';
import { services } from '../../data/services';
---

<BaseLayout
  title="Layanan Hukum & Perizinan | IZINKU"
  description="Layanan hukum profesional dari IZINKU: pendirian usaha, penyusunan MoU & kontrak bisnis, dan konsultasi hukum retainer untuk UMKM."
>
  <!-- Page Header -->
  <section class="bg-primary py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4">
        Layanan Kami
      </h1>
      <p class="text-white/70 text-lg max-w-2xl mx-auto">
        Solusi hukum menyeluruh untuk setiap tahap perjalanan bisnis Anda
      </p>
    </div>
  </section>

  <!-- Service Cards -->
  <section class="py-16 md:py-24 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8">
        {services.map((service) => (
          <ServiceCard service={service} />
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 md:py-24 bg-cream-alt">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="Mengapa Memilih IZINKU?"
        subtitle="Keunggulan layanan kami yang membedakan dari yang lain"
      />
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
        {[
          { icon: '⚡', title: 'Proses Cepat', desc: 'Efisiensi waktu dengan sistem kerja yang terstruktur.' },
          { icon: '🛡️', title: 'Legal & Terpercaya', desc: 'Tim advokat berpengalaman dan bersertifikat.' },
          { icon: '💰', title: 'Harga Transparan', desc: 'Tidak ada biaya tersembunyi, semua jelas di awal.' },
          { icon: '📞', title: 'Responsif 24 Jam', desc: 'Tim kami siap membantu kapan pun Anda butuhkan.' },
        ].map((item) => (
          <div class="text-center p-6 bg-white rounded-xl border border-primary/5">
            <div class="text-3xl mb-3">{item.icon}</div>
            <h3 class="font-heading font-bold text-primary mb-2">{item.title}</h3>
            <p class="text-text-secondary text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
