---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FounderProfile from '../components/tentang/FounderProfile.astro';
import TeamGrid from '../components/tentang/TeamGrid.astro';
import StatsCounter from '../components/home/StatsCounter.astro';
import CTABanner from '../components/CTABanner.astro';
---

<BaseLayout
  title="Tentang IZINKU — Mitra Hukum UMKM Indonesia"
  description="Kenali IZINKU lebih dekat — tim advokat berpengalaman yang berdedikasi membantu UMKM Indonesia mendapatkan legalitas usaha."
>
  <!-- Page Header -->
  <section class="bg-primary py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4">
        Tentang Kami
      </h1>
      <p class="text-white/70 text-lg max-w-2xl mx-auto">
        Mengenal lebih dekat tim di balik IZINKU
      </p>
    </div>
  </section>

  <!-- Founder -->
  <FounderProfile />

  <!-- Mission & Vision -->
  <section class="py-16 md:py-24 bg-cream-alt">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Vision -->
        <div class="bg-white rounded-2xl p-8 border border-primary/5">
          <div class="w-12 h-12 bg-gold/20 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-primary mb-4">Visi Kami</h3>
          <p class="text-text-secondary leading-relaxed">
            Menjadi mitra hukum terdepan yang membuat layanan legal profesional dapat diakses oleh seluruh pelaku UMKM di Indonesia, tanpa batasan lokasi dan biaya yang memberatkan.
          </p>
        </div>

        <!-- Mission -->
        <div class="bg-white rounded-2xl p-8 border border-primary/5">
          <div class="w-12 h-12 bg-gold/20 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-primary mb-4">Misi Kami</h3>
          <ul class="space-y-3 text-text-secondary text-sm leading-relaxed">
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-gold shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              <span>Menyederhanakan proses hukum bagi pelaku usaha</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-gold shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              <span>Memberikan layanan hukum berkualitas dengan harga terjangkau</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-gold shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              <span>Mengedukasi UMKM tentang pentingnya legalitas usaha</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-gold shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              <span>Membangun ekosistem bisnis Indonesia yang legal dan transparan</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <StatsCounter />

  <!-- Team -->
  <section class="py-16 md:py-24 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="Tim Kami"
        subtitle="Profesional berpengalaman yang siap membantu Anda"
      />
      <TeamGrid />
    </div>
  </section>

  <CTABanner />
</BaseLayout>
